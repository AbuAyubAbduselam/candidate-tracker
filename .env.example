# Copy this file to ".env.local" and fill in your real Supabase values.
# Find them in: Supabase Dashboard → Project Settings → API
#
# NOTE: use your PUBLISHABLE / anon key here — never your project's secret key.

VITE_SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY

# ── Optional: import candidates from the Agency site by passport number ──
# Point these at the AGENCY Supabase project (its PUBLISHABLE / anon key).
# Requires running agency-lookup.sql once in the agency project first.
# Leave blank to disable the "Import from agency" feature.
VITE_AGENCY_SUPABASE_URL=YOUR_AGENCY_SUPABASE_PROJECT_URL
VITE_AGENCY_SUPABASE_ANON_KEY=YOUR_AGENCY_SUPABASE_ANON_PUBLIC_KEY
